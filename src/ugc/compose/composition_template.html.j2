<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width={{ width }}, height={{ height }}" />
  <title>{{ brief.name }} — variant {{ variant.index }}</title>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js"></script>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html, body {
      margin: 0;
      width: {{ width }}px;
      height: {{ height }}px;
      overflow: hidden;
      background: var(--bg);
      color: var(--fg);
      font-family: -apple-system, "Inter", "Helvetica Neue", system-ui, sans-serif;
    }
    :root {
      --bg: {{ brief.visuals.background_color }};
      --accent: {{ brief.visuals.accent_color }};
      --fg: #f6f7fb;
    }
    #root { position: relative; width: {{ width }}px; height: {{ height }}px; }
    .clip { position: absolute; inset: 0; opacity: 0; }
    video.clip, img.clip { width: 100%; height: 100%; object-fit: cover; }
    .overlay {
      display: flex; align-items: center; justify-content: center;
      flex-direction: column; padding: 8% 10%; text-align: center;
      background: var(--bg);
    }
    .overlay .headline {
      font-size: 96px; font-weight: 800; line-height: 1.05;
      color: var(--fg); letter-spacing: -0.02em;
    }
    .overlay .subhead {
      margin-top: 32px; font-size: 36px; font-weight: 500;
      color: var(--accent); letter-spacing: 0.02em;
    }
    .overlay.social-proof .headline { color: var(--accent); font-size: 144px; }
    .overlay.social-proof .label {
      margin-top: 28px; font-size: 38px; font-weight: 500; color: var(--fg);
    }
    .caption {
      position: absolute; left: 8%; right: 8%;
      top: auto; bottom: 14%;
      max-height: 30%; overflow: hidden;
      display: -webkit-box; -webkit-line-clamp: 4; -webkit-box-orient: vertical;
      text-align: center; font-weight: 700;
      {% if caption_energy == "hype" %}
      font-size: 84px; color: var(--accent);
      text-shadow: 0 0 24px rgba(0,0,0,0.6);
      {% elif caption_energy == "tutorial" %}
      font-size: 56px; color: var(--fg);
      font-family: "JetBrains Mono", "SF Mono", monospace;
      {% else %}
      font-size: 64px; color: var(--fg);
      text-shadow: 0 2px 10px rgba(0,0,0,0.45);
      {% endif %}
      letter-spacing: -0.01em; line-height: 1.15;
    }
    .url-burn {
      position: absolute; left: 0; right: 0;
      top: auto; bottom: 6%;
      text-align: center; color: var(--accent);
      font-size: 56px; font-weight: 800; letter-spacing: 0.02em;
      text-shadow: 0 2px 12px rgba(0,0,0,0.6);
    }
  </style>
</head>
<body>
<div id="root"
     data-composition-id="{{ composition_id }}"
     data-start="0"
     data-duration="{{ '%.3f' % total_duration }}"
     data-width="{{ width }}"
     data-height="{{ height }}">

{% for scene in scenes %}
  {% if scene.kind == "avatar" %}
  <video class="clip"
         id="scene-{{ scene.index }}"
         data-start="{{ '%.3f' % scene.start }}"
         data-duration="{{ '%.3f' % scene.duration }}"
         data-track-index="0"
         src="{{ avatar_clip_paths[scene.index] }}"
         muted
         playsinline></video>
  {% if scene.spoken_text %}
  <div class="clip caption"
       id="caption-{{ scene.index }}"
       data-start="{{ '%.3f' % scene.start }}"
       data-duration="{{ '%.3f' % scene.duration }}"
       data-track-index="2">{{ scene.spoken_text.split('. ')[0] | truncate(90, end='…') }}{% if '. ' in scene.spoken_text %}.{% endif %}</div>
  {% endif %}
  {% if scene.burn_in_text %}
  <div class="clip url-burn"
       id="urlburn-{{ scene.index }}"
       data-start="{{ '%.3f' % scene.start }}"
       data-duration="{{ '%.3f' % scene.duration }}"
       data-track-index="3">{{ scene.burn_in_text }}</div>
  {% endif %}
  {% else %}
  <div class="clip overlay {{ scene.block }}"
       id="scene-{{ scene.index }}"
       data-start="{{ '%.3f' % scene.start }}"
       data-duration="{{ '%.3f' % scene.duration }}"
       data-track-index="1"
       data-block="{{ scene.block }}">
    {% if scene.block == "pattern-interrupt" %}
    <div class="headline">{{ scene.block_props.headline }}</div>
    {% if scene.block_props.subhead %}
    <div class="subhead">{{ scene.block_props.subhead }}</div>
    {% endif %}
    {% elif scene.block == "social-proof" %}
    <div class="headline">{{ scene.block_props.headline }}</div>
    {% if scene.block_props.label %}
    <div class="label">{{ scene.block_props.label }}</div>
    {% endif %}
    {% endif %}
  </div>
  {% endif %}
{% endfor %}

{% if music_asset %}
  <audio id="bgm"
         class="clip"
         data-start="0"
         data-duration="{{ '%.3f' % total_duration }}"
         data-track-index="9"
         data-volume="{{ music_volume }}"
         src="{{ music_asset }}"></audio>
{% endif %}

</div>

<script>
  // GSAP timeline registration — HF seeks this frame-by-frame.
  // EVERY element with class="clip" must have explicit fade-in / fade-out
  // / hard-kill tweens or it stays at the CSS-default opacity:0 forever.
  window.__timelines = window.__timelines || {};
  (function () {
    const tl = gsap.timeline({ paused: true });
    function fade(selector, start, duration) {
      tl.fromTo(selector,
        { opacity: 0 },
        { opacity: 1, duration: 0.25, ease: "power2.out" },
        start);
      tl.to(selector,
        { opacity: 0, duration: 0.2, ease: "power2.in" },
        Math.max(start, start + duration - 0.2));
      tl.set(selector, { opacity: 0 }, start + duration);
    }
    {% for scene in scenes %}
    fade("#scene-{{ scene.index }}", {{ '%.3f' % scene.start }}, {{ '%.3f' % scene.duration }});
    {% if scene.kind == "avatar" and scene.spoken_text %}
    fade("#caption-{{ scene.index }}", {{ '%.3f' % scene.start }}, {{ '%.3f' % scene.duration }});
    {% endif %}
    {% if scene.kind == "avatar" and scene.burn_in_text %}
    fade("#urlburn-{{ scene.index }}", {{ '%.3f' % scene.start }}, {{ '%.3f' % scene.duration }});
    {% endif %}
    {% endfor %}
    {% if music_asset %}
    // Audio doesn't need opacity, but HF still expects the timeline to
    // reference it. Set volume on the audio element directly.
    tl.set("#bgm", { volume: {{ music_volume }} }, 0);
    {% endif %}
    window.__timelines["{{ composition_id }}"] = tl;
  })();
</script>
</body>
</html>
